{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hiimomagh.github.io/jarbou3i-research-engine/schema/research-workflow.schema.json",
  "title": "Jarbou3i Research Workflow Beta Schema",
  "type": "object",
  "required": [
    "workflow_version",
    "research_plan",
    "evidence_matrix",
    "causal_links",
    "analysis_brief",
    "diagnostics",
    "ai_runs"
  ],
  "properties": {
    "workflow_version": {
      "const": "0.10.0-beta"
    },
    "generated_at": {
      "type": "string"
    },
    "research_plan": {
      "$ref": "#/$defs/research_plan"
    },
    "evidence_matrix": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_item"
      },
      "minItems": 1
    },
    "causal_links": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/causal_link"
      },
      "minItems": 1
    },
    "analysis_brief": {
      "anyOf": [
        {
          "$ref": "#/$defs/analysis_brief"
        },
        {
          "type": "null"
        }
      ]
    },
    "diagnostics": {
      "anyOf": [
        {
          "$ref": "#/$defs/diagnostics"
        },
        {
          "type": "null"
        }
      ]
    },
    "provider": {
      "type": "string"
    },
    "ai_runs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ai_run"
      }
    },
    "critique": {
      "type": [
        "object",
        "null"
      ]
    },
    "provider_config": {
      "anyOf": [
        {
          "$ref": "#/$defs/provider_config"
        },
        {
          "type": "null"
        }
      ]
    },
    "provider_validation": {
      "anyOf": [
        {
          "$ref": "#/$defs/response_validation"
        },
        {
          "type": "null"
        }
      ]
    },
    "repair_trace": {
      "anyOf": [
        {
          "$ref": "#/$defs/repair_trace"
        },
        {
          "type": "null"
        }
      ]
    },
    "provider_diagnostics": {
      "anyOf": [
        {
          "$ref": "#/$defs/provider_diagnostics"
        },
        {
          "type": "null"
        }
      ]
    },
    "provider_fixture_report": {
      "anyOf": [
        {
          "$ref": "#/$defs/provider_fixture_report"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "$defs": {
    "research_plan": {
      "type": "object",
      "required": [
        "plan_version",
        "topic",
        "context",
        "mode",
        "questions",
        "target_actors",
        "target_sources",
        "counter_evidence_targets",
        "early_warning_indicators"
      ],
      "properties": {
        "plan_version": {
          "const": "0.10.0-beta"
        },
        "topic": {
          "type": "string",
          "minLength": 1
        },
        "context": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "enum": [
            "structural",
            "recent",
            "source-heavy",
            "adversarial"
          ]
        },
        "generated_at": {
          "type": "string"
        },
        "questions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 3
        },
        "target_actors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "target_sources": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "counter_evidence_targets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "early_warning_indicators": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      },
      "additionalProperties": true
    },
    "evidence_item": {
      "type": "object",
      "required": [
        "evidence_id",
        "claim",
        "source_type",
        "source_date",
        "time_relevance_score",
        "evidence_strength",
        "public_signal_score",
        "supports",
        "contradicts",
        "confidence"
      ],
      "properties": {
        "evidence_id": {
          "type": "string",
          "pattern": "^E[0-9]+$"
        },
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "source_title": {
          "type": "string"
        },
        "source_url": {
          "type": "string"
        },
        "source_type": {
          "enum": [
            "official",
            "academic",
            "news",
            "social",
            "market",
            "expert",
            "primary",
            "other"
          ]
        },
        "source_date": {
          "type": "string"
        },
        "time_relevance_score": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "evidence_strength": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "public_signal_score": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "supports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contradicts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "causal_link": {
      "type": "object",
      "required": [
        "from",
        "to",
        "relationship",
        "evidence_ids",
        "confidence"
      ],
      "properties": {
        "from": {
          "type": "string",
          "pattern": "^[A-Z]+[0-9]+$"
        },
        "to": {
          "type": "string",
          "pattern": "^[A-Z]+[0-9]+$"
        },
        "relationship": {
          "enum": [
            "motivates",
            "enables",
            "constrains",
            "contradicts",
            "amplifies"
          ]
        },
        "evidence_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^E[0-9]+$"
          },
          "minItems": 1
        },
        "confidence": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      },
      "additionalProperties": true
    },
    "source_cluster": {
      "type": "object",
      "required": [
        "cluster_id",
        "target_id",
        "layer",
        "evidence_ids",
        "claims",
        "source_types",
        "average_strength",
        "contradiction_count",
        "confidence_mix"
      ],
      "properties": {
        "cluster_id": {
          "type": "string",
          "pattern": "^CL[0-9]+$"
        },
        "target_id": {
          "type": "string"
        },
        "layer": {
          "type": "string"
        },
        "evidence_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "claims": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "average_strength": {
          "type": "number"
        },
        "contradiction_count": {
          "type": "number"
        },
        "confidence_mix": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "analysis_brief": {
      "type": "object",
      "required": [
        "brief_version",
        "topic",
        "context",
        "readiness_score",
        "source_clusters",
        "coverage",
        "gaps",
        "synthesis_constraints",
        "handoff_summary"
      ],
      "properties": {
        "brief_version": {
          "const": "0.10.0-beta"
        },
        "generated_at": {
          "type": "string"
        },
        "topic": {
          "type": "string"
        },
        "context": {
          "type": "string"
        },
        "mode": {
          "type": "string"
        },
        "readiness_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "research_questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_clusters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_cluster"
          }
        },
        "coverage": {
          "type": "object"
        },
        "gaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence_priorities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "synthesis_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "handoff_summary": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "ai_run": {
      "type": "object",
      "required": [
        "run_id",
        "run_version",
        "provider",
        "task",
        "status",
        "input_fingerprint",
        "response_type",
        "response_contract",
        "output_summary",
        "response_validation",
        "repair_trace"
      ],
      "properties": {
        "run_id": {
          "type": "string"
        },
        "run_version": {
          "const": "0.10.0-beta"
        },
        "provider": {
          "type": "string"
        },
        "task": {
          "enum": [
            "plan",
            "synthesis",
            "repair",
            "critique",
            "source_discipline"
          ]
        },
        "status": {
          "enum": [
            "ok",
            "repaired",
            "validation_error",
            "error"
          ]
        },
        "started_at": {
          "type": "string"
        },
        "completed_at": {
          "type": "string"
        },
        "duration_ms": {
          "type": "number"
        },
        "input_fingerprint": {
          "type": "string"
        },
        "response_type": {
          "type": "string"
        },
        "response_contract": {
          "type": "object"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "output_summary": {
          "type": "string"
        },
        "provider_safety": {
          "type": "object"
        },
        "response_validation": {
          "$ref": "#/$defs/response_validation"
        },
        "repair_trace": {
          "$ref": "#/$defs/repair_trace"
        }
      },
      "additionalProperties": true
    },
    "diagnostics": {
      "type": "object",
      "required": [
        "diagnostics_version",
        "coverage",
        "gaps",
        "status"
      ],
      "properties": {
        "diagnostics_version": {
          "const": "0.10.0-beta"
        },
        "generated_at": {
          "type": "string"
        },
        "linked_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "coverage": {
          "type": "object"
        },
        "gaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_evidence_references": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "enum": [
            "review_required",
            "synthesis_ready"
          ]
        }
      },
      "additionalProperties": true
    },
    "provider_config": {
      "type": "object",
      "required": [
        "endpoint",
        "model",
        "allow_live",
        "remember_key"
      ],
      "properties": {
        "endpoint": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "allow_live": {
          "type": "boolean"
        },
        "remember_key": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "response_validation": {
      "type": "object",
      "required": [
        "validation_version",
        "task",
        "expected_type",
        "received_type",
        "accepted",
        "repair_required",
        "issue_count",
        "issues"
      ],
      "properties": {
        "validation_version": {
          "const": "0.10.0-beta"
        },
        "validated_at": {
          "type": "string"
        },
        "task": {
          "type": "string"
        },
        "expected_type": {
          "type": "string"
        },
        "received_type": {
          "type": "string"
        },
        "accepted": {
          "type": "boolean"
        },
        "repair_required": {
          "type": "boolean"
        },
        "issue_count": {
          "type": "number"
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "repair_trace": {
      "type": "object",
      "required": [
        "attempted",
        "status"
      ],
      "properties": {
        "attempted": {
          "type": "boolean"
        },
        "strategy": {
          "type": "string"
        },
        "status": {
          "enum": [
            "not_required",
            "repaired",
            "failed"
          ]
        },
        "original_task": {
          "type": "string"
        },
        "repair_task": {
          "type": "string"
        },
        "original_issues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "provider_diagnostics": {
      "type": "object",
      "required": [
        "diagnostics_version",
        "task",
        "provider",
        "contract_type",
        "prompt_chars",
        "key_exported",
        "readiness",
        "warnings"
      ],
      "properties": {
        "diagnostics_version": {
          "const": "0.10.0-beta"
        },
        "checked_at": {
          "type": "string"
        },
        "task": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "contract_type": {
          "type": "string"
        },
        "required_count": {
          "type": "number"
        },
        "prompt_chars": {
          "type": "number"
        },
        "input_fingerprint": {
          "type": "string"
        },
        "privacy_mode": {
          "type": "string"
        },
        "key_exported": {
          "const": false
        },
        "live_opt_in": {
          "type": "boolean"
        },
        "readiness": {
          "enum": [
            "provider_ready",
            "review_required"
          ]
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "provider_fixture_report": {
      "type": "object",
      "required": [
        "suite_version",
        "fixture_count",
        "pass_count",
        "fail_count",
        "results"
      ],
      "properties": {
        "suite_version": {
          "const": "0.10.0-beta"
        },
        "fixture_count": {
          "type": "number"
        },
        "pass_count": {
          "type": "number"
        },
        "fail_count": {
          "type": "number"
        },
        "results": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": true
    }
  }
}