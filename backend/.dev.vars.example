# Copy to backend/.dev.vars for local Worker testing.
# Never commit real secrets.
OPENAI_API_KEY=sk-your-local-test-key
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4.1-mini
ALLOWED_MODELS=gpt-4.1-mini,gpt-4.1
ALLOWED_ORIGINS=http://localhost:4173,http://localhost:8787
MAX_PROMPT_CHARS=30000
MAX_BODY_BYTES=180000
MAX_UPSTREAM_BYTES=400000
PROVIDER_TIMEOUT_MS=25000
RATE_LIMIT_SECONDS=8
AUDIT_LOGS_ENABLED=false

# v0.27 GitHub public source connector
SOURCE_GITHUB_ENABLED=true
SOURCE_TIMEOUT_MS=15000
SOURCE_GITHUB_RELEASE_LIMIT=5
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_API_VERSION=2022-11-28
# Optional server-side token for public API rate limits; never expose this in frontend exports.
# GITHUB_TOKEN=github_pat_optional_server_side_only
