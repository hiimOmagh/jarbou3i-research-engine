{
  "name": "jarbou3i-research-engine",
  "version": "0.1.0-alpha",
  "private": true,
  "description": "Jarbou3i Research Engine alpha: an experimental research-to-strategy workflow layer with research planning, evidence matrix, mock AI workflow, and Quality Gate v2.",
  "scripts": {
    "dev": "http-server . -p 4173 -c-1",
    "test": "npm run test:qa && npm run test:browser",
    "test:qa": "node tests/qa-check.mjs && node tests/research-workflow-check.mjs",
    "test:static": "node tests/static-check.mjs",
    "test:schema": "node tests/schema-check.mjs",
    "test:fixtures": "node tests/fixtures-check.mjs",
    "test:research": "node tests/research-workflow-check.mjs",
    "test:a11y:static": "node tests/a11y-static-check.mjs",
    "test:browser": "playwright test",
    "test:e2e": "playwright test tests/smoke.spec.js",
    "test:rtl": "playwright test tests/rtl-mobile.spec.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "http-server": "^14.1.1"
  }
}
